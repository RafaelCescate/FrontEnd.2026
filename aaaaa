#include <stdlib.h>
#include <stdio.h>
#include <time.h>

void push(int item); 	//empilhar
void pop();				//desempilhar
void imprimir();
void push5();
int entrada_dados();

typedef struct apelido_no{
	int dado;
	struct apelido_no *proximo;
}no;

no *top=NULL;
//--------------------------------------------------------------------------------------------------------
int main(){
	int n, opcao;
	srand(time(NULL));
	do{
		system("cls");
		printf("\n\nMenu\n1. Empilhar \n2. Desempilhar\n3. Imprimir \n4. Empilher 5 Valores de 10 a 100 \n5. Sair");
		printf("\nEscolha uma opcao (0-4): ");
		scanf("%d", &opcao);
		switch(opcao){
			case 1:
				n=entrada_dados();
				push(n); //empilhar
				break;
				system("pause");
			case 2:
				pop(); //desempilhar
				break;
			case 3:
				imprimir(); //imprimir
				break;
			case 4:
				push5(); //empilhar 5 valores entre 10 e 100
				break;
		}
	}while(opcao!=5);
	return 0;
}
//--------------------------------------------------------------------------------------------------------
void push(int item){
	printf("\nEMPILHANDO...\n");
	no *novo=malloc(sizeof(no));
	//necessário verificar se há memória
	novo->dado=item;
	novo->proximo=top;
	top=novo;
	printf("\nValor %d empilhando\n", novo->dado);
}
//--------------------------------------------------------------------------------------------------------
void pop(){
	printf("\nDESEMPILHANDO...\n");
	if(top==NULL)
		printf("A pilha esta vazia\n");
	else{
		no *temp;
		temp=top;
		top=top->proximo;
		printf("\n%d Desempilhado com sucesso\n", temp->dado);
		free(temp);
	}
	system("pause");
}
//--------------------------------------------------------------------------------------------------------
void imprimir(){
	no *temp;
	temp=top;
	printf("\nIMPRIMINDO PILHA...\n");
	while(temp!=NULL){
		printf("%d\n",temp->dado);
		temp=temp->proximo;
	}
	system("pause");
}
//--------------------------------------------------------------------------------------------------------
int entrada_dados(){
	int valor;
	printf("\nEntre com valor a empilhar: ");
	scanf("%d", &valor);
	return valor;
}
//--------------------------------------------------------------------------------------------------------
void push5(){
	int x;
	for(x=0; x<5; x++){
		int y=rand()%91+10;
		push(y);
	}
	system("pause");
}
